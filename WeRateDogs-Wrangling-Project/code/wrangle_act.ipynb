          }
        },
        "id": "Ek9HPoX7RAuh"
      },
      "source": [
        "#### Define: The `source` column contains HTML tags that need to be removed to extract clean source information."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "XBq2tzFQRKxU"
      },
      "source": []
    },
    {
      "cell_type": "code",
      "execution_count": 65,
      "metadata": {
        "id": "-IvTQDosjFvW"
      },
      "outputs": [],
      "source": [
        "# Extracting the source URL from the 'source' column using a regular expression and removing HTML tags\n",
        "twitter_archive['source'] = twitter_archive['source'].str.extract(r'<a href=\"(.+)\">.+</a>', expand=False)\n",
        "\n",
        "# Removing any remaining double quotes from the 'source' column\n",
        "twitter_archive['source'] = twitter_archive['source'].str.replace('\"', '')"
      ]
    },
