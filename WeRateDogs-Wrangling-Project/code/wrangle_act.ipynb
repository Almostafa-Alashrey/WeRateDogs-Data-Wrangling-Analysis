      },
      "source": [
        "#### Define: The `rating_numerator` and `rating_denominator` columns in the `twitter_archive` dataset need to be merged into a single `rating` column to represent the dog's rating more concisely."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "Kdn5KOLNuYHF"
      },
      "source": []
    },
    {
      "cell_type": "code",
      "execution_count": 75,
      "metadata": {
        "id": "COfR4Kb_ueNr"
      },
      "outputs": [],
      "source": [
        "# Creating a new column 'rating' in the twitter_archive DataFrame by concatenating 'rating_numerator' and 'rating_denominator' with a '/' separator\n",
        "twitter_archive['rating'] = twitter_archive['rating_numerator'] + '/' + twitter_archive['rating_denominator']\n",
        "\n",
        "# Dropping the 'rating_numerator' and 'rating_denominator' columns from the twitter_archive DataFrame as they are no longer needed\n",
        "twitter_archive = twitter_archive.drop(columns=['rating_numerator', 'rating_denominator'])"
      ]
    },
