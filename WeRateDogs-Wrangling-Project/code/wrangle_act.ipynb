    {
      "cell_type": "markdown",
      "metadata": {
        "id": "AhofpXvBRCA1"
      },
      "source": [
        "## Storing Data\n",
        "This section focuses on storing the gathered, assessed, and cleaned master dataset. The final dataset will be saved as a CSV file named \"twitter_archive_master.csv\" for future use and analysis."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 79,
      "metadata": {
        "id": "RRC9iTd2_Erl"
      },
      "outputs": [],
      "source": [
        "# Ensure tweet_id is string type for consistent merging across all dataframes\n",
        "twitter_archive['tweet_id'] = twitter_archive['tweet_id'].astype(str)\n",
        "tweet_df['tweet_id'] = tweet_df['tweet_id'].astype(str)\n",
        "image_predictions['tweet_id'] = image_predictions['tweet_id'].astype(str)\n",
        "\n",
        "# Start with the cleaned twitter_archive data\n",
        "twitter_archive_master = twitter_archive.copy()\n",
        "\n",
        "# Merging with tweet_df to add retweet_count and favorite_count\n",
        "twitter_archive_master = pd.merge(twitter_archive_master, tweet_df, on='tweet_id', how='left')\n",
        "\n",
        "# Merging with image_predictions to add image prediction details\n",
        "twitter_archive_master = pd.merge(twitter_archive_master, image_predictions, on='tweet_id', how='left')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 80,
      "metadata": {
        "id": "YnxEQKugOn4X"
      },
      "outputs": [],
      "source": [
        "# Handle missing values before filtering\n",
        "twitter_archive_master.dropna(subset=['name'], inplace=True)\n",
        "\n",
        "# remove retweets (text starting with RT @)\n",
        "twitter_archive_master.drop(\n",
        "    twitter_archive_master.loc[twitter_archive_master[\"name\"].str.startswith(\"@ RT\")].index,\n",
        "    inplace=True\n",
        ")"
      ]
    },
