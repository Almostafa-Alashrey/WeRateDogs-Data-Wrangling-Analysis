      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# First, ensure 'rating' is properly converted to a numerical value (numerator / denominator).\n",
        "# The 'rating' column is currently in 'X/Y' string format.\n",
        "\n",
        "# Define a function to convert 'X/Y' rating strings to a float\n",
        "def parse_rating_to_float(rating_str):\n",
        "    if pd.isna(rating_str) or not isinstance(rating_str, str): # Handle NaN or non-string values\n",
        "        return np.nan\n",
        "    try:\n",
        "        parts = rating_str.split('/')\n",
        "        if len(parts) == 2:\n",
        "            numerator = float(parts[0])\n",
        "            denominator = float(parts[1])\n",
        "            if denominator != 0: # Avoid division by zero\n",
        "                return numerator / denominator\n",
        "    except ValueError:\n",
        "        pass # If conversion fails, return NaN\n",
        "    return np.nan\n",
        "\n",
        "# Apply the conversion function to the 'rating' column\n",
        "twitter_archive_master['parsed_rating'] = twitter_archive_master['rating'].apply(parse_rating_to_float)\n",
        "\n",
        "# Group by dog breed and calculate average parsed_rating and total retweets/favorites\n",
        "breed_stats = twitter_archive_master.groupby('dog_breed').agg({'parsed_rating': 'mean', 'retweet_count': 'sum', 'favorite_count': 'sum'}).reset_index()\n",
        "\n",
        "# Rename the 'parsed_rating' column to 'average_rating' for clarity\n",
        "breed_stats = breed_stats.rename(columns={'parsed_rating': 'average_rating'})\n",
        "\n",
        "# Sort by average rating in descending order\n",
        "breed_stats_sorted = breed_stats.sort_values('average_rating', ascending=False)\n",
        "\n",
        "display(breed_stats_sorted.head())\n",
        "\n",
        "# Create a bar chart for total retweets\n",
        "plt.figure(figsize=(10, 6)) # Adjusted size for better visibility\n",
        "sns.barplot(x='dog_breed', y='retweet_count', data=breed_stats_sorted.head(10), palette='viridis', hue='dog_breed', legend=False)\n",
        "plt.xlabel('Dog Breed')\n",
        "plt.ylabel('Total Retweets')\n",
        "plt.title('Top 10 Dog Breeds by Total Retweets')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Create a bar chart for total favorites\n",
        "plt.figure(figsize=(10, 6)) # Adjusted size for better visibility\n",
        "sns.barplot(x='dog_breed', y='favorite_count', data=breed_stats_sorted.head(10), palette='magma', hue='dog_breed', legend=False)\n",
        "plt.xlabel('Dog Breed')\n",
        "plt.ylabel('Total Favorites')\n",
        "plt.title('Top 10 Dog Breeds by Total Favorites')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    }
